NODE_ENV=development
PORT=3001

# Authentication
JWT_SECRET=your_jwt_secret_here_at_least_64_chars_long

# Wallet encryption — must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here_000000000000000000000000000000

# Stellar issuer / admin keypair (holds pool funds + sponsors fee-bumps)
ISSUER_SECRET_KEY=S_your_stellar_secret_key_here

# Deployed contract IDs (Stellar testnet)
PHPC_ID=CD2GKG5HM5FMFCN4OMPXKTBHC23N2EFIQGESQV46WJGZAD76FP7SLPJR
REGISTRY_ID=CDP3FEVG46ZUH73VZLDFQWHZHEIHITM3FVG26ZR4I3RY34HSWVNWHVPZ
LENDING_POOL_ID=CDRE2MZVSHOWEITL7UBBTNIHRH6IC5USDKY5K5AFELPJZ7VMEV5LQVWH

# Stellar network (defaults shown are for testnet)
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# Optional — defaults to backend/kredito.db
# DATABASE_PATH=/data/kredito.db
