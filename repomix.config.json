{
  "output": {
    "filePath": "repomix-output.md",
    "style": "markdown",
    "removeComments": true,
    "removeEmptyLines": true,
    "topFilesLength": 5
  },
  "include": [
    "backend/**/*",
    "frontend/**/*",
    "contracts/**/*",
    "docs/**/*",
    "README.md",
    "DEMO.md",
    "package.json",
    ".gitignore",
    ".repomixignore",
    "repomix.config.json",
    "skills-lock.json"
  ],
  "ignore": {
    "customPatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.next/**",
      "**/target/**",
      "**/*.lock",
      "**/pnpm-lock.yaml",
      "**/*.db*",
      "**/*.sqlite*",
      "**/*.log",
      "**/.env",
      "**/.env.local",
      "**/.env.*.local",
      "**/*.tsbuildinfo",
      "**/images/**",
      "**/*.{png,jpg,jpeg,gif,svg,ico,webp,pdf,zip}",
      "**/.git/**",
      "**/.github/**",
      "**/.agents/**",
      "**/.DS_Store",
      "**/test_snapshots/**",
      "**/__snapshots__/**",
      "**/*.test.ts.snap",
      "repomix-output.md",
      "docs/SETUP.md",
      "docs/SPEC.md",
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/tests/**",
      "**/__tests__/**"
    ]
  }
}
